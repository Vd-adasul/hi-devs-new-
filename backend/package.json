{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --dns-result-order=ipv4first --env-file=.env node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "npm --prefix packages/types run build && tsc",
    "start": "node --dns-result-order=ipv4first dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "backfill-es-index": "tsx --env-file=.env scripts/backfill-es-index.ts",
    "cleanup-broken-drafts": "tsx scripts/cleanup-broken-drafts.ts",
    "clean-demo": "tsx scripts/clean-demo.ts",
    "backfill-unnamed-titles": "tsx scripts/backfill-unnamed-titles.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@anthropic-ai/sdk": "^0.24.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@bull-board/api": "5.23.0",
    "@bull-board/fastify": "5.23.0",
    "@clm/types": "file:./packages/types",
    "@elastic/elasticsearch": "8",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@hocuspocus/server": "^4.0.0",
    "@mastra/core": "^1.49.0",
    "@opensearch-project/opensearch": "^3.0.0",
    "@prisma/client": "^5.16.0",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.12.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mastra": "^1.18.0",
    "neo4j-driver": "^6.2.0",
    "node-forge": "^1.4.0",
    "node-htmldiff": "^0.9.4",
    "nodemailer": "^6.9.14",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "1",
    "pino": "^9.3.0",
    "ws": "^8.20.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^3.23.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^6.4.24",
    "prisma": "^5.16.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {}
}